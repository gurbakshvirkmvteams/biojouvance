{{ 'custom.css' | asset_url | stylesheet_tag }}
<div class="custom-video-container" style="padding-top:{{ section.settings.padding_top }}px; padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="custom-video-wrapper">

    {% if section.settings.left_video %}
      <div class="custom-video-card">
        {{
          section.settings.left_video
          | video_tag:
            controls: true,
            autoplay: false,
            loop: false,
            muted: false,
            image_size: '800x'
        }}
      </div>
    {% endif %}

    {% if section.settings.right_video %}
      <div class="custom-video-card">
        {{
          section.settings.right_video
          | video_tag:
            controls: true,
            autoplay: false,
            loop: false,
            muted: false,
            image_size: '800x'
        }}
      </div>
    {% endif %}

  </div>
</div>
{% schema %}
  {
    "name": "Custom Video Section",
    "settings": [
      {
        "type": "video",
        "id": "left_video",
        "label": "Left section Video"
      }, {
        "type": "video",
        "id": "right_video",
        "label": "Right section Video"
      }, {
        "type": "range",
        "id": "padding_top",
        "label": "Padding Top",
        "min": 0,
        "max": 150,
        "step": 5,
        "unit": "px",
        "default": 50
      }, {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding Bottom",
        "min": 0,
        "max": 150,
        "step": 5,
        "unit": "px",
        "default": 50
      }
    ],
    "presets": [
      {
        "name": "Custom Video Section"
      }
    ]
  }
{% endschema %}