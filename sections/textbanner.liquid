{{ 'custom.css' | asset_url | stylesheet_tag }}

{% if section.settings.banner_text != blank %}
  <div class="text-banner-text-container" style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: {{ section.settings.text_alignment }};
    color: {{ section.settings.banner_text_color }};">{{ section.settings.banner_text }}</div>
{% endif %}

{% schema %}
  {
    "name": "Add Text Banner",
    "settings": [
      {
        "label": "Banner Heading",
        "type": "richtext",
        "id": "banner_text"
      },
      {
        "type": "color",
        "id": "banner_text_color",
        "label": "Banner Heading Color",
        "default": "#000000"
      },
      {
        "type": "select",
        "id": "text_alignment",
        "label": "Text Alignment",
        "default": "left",
        "options": [
          {
            "value": "left",
            "label": "Left"
          }, {
            "value": "center",
            "label": "Center"
          }, {
            "value": "right",
            "label": "Right"
          }
        ]
      },
      {
        "type": "range",
        "id": "padding_top",
        "label": "Padding Top",
        "min": 50,
        "max": 300,
        "step": 5,
        "unit": "px",
        "default": 50
      }, {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding Bottom",
        "min": 50,
        "max": 300,
        "step": 5,
        "unit": "px",
        "default": 50
      }
    ],
    "presets": [
      {
        "name": "Text Banner Section"
      }
    ]
  }
{% endschema %}