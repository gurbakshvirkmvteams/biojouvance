{{ 'custom.css' | asset_url | stylesheet_tag }}

{% if section.settings.my_custom_image != blank %}
  <div class="custom-banner-section-wrapper" style=" background-image: url({{ section.settings.my_custom_image | image_url: width: 1600 }}); min-height:{{ section.settings.section_min_height }}px">
    {% comment %} <div class="custom-banner" style="background-image: url({{ section.settings.my_custom_image | image_url: width: 1600 }}); padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"> {% endcomment %}
    <div class="custom-banner {% if section.settings.layout == 'text_first' %}text-left{% else %}text-right{% endif %}" style="
   
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    ">
      <div class="banner-text-container" style="max-width: {{section.settings.banner_text_width}}px;">
        {% comment %} this needs customised max width  {% endcomment %}
        {% if section.settings.short_heading != blank %}
          <span class="banner-short-heading">
            {{ section.settings.short_heading }}
          </span>
        {% endif %}

        <h1>{{ section.settings.heading }}</h1>

        <p>{{ section.settings.description }}</p>

        {% if section.settings.banner_button_text != blank and section.settings.banner_button_link != blank
        %}
          <a href="{{ section.settings.banner_button_link }}" class="banner-button">
            {{ section.settings.banner_button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
  {
    "name": "Custom Image",
    "settings": [
      {
        "type": "image_picker",
        "id": "my_custom_image",
        "label": "Choose Image"
      },
      {
        "label": "Short Heading",
        "type": "text",
        "id": "short_heading"
      },
      {
        "label": "Heading",
        "type": "text",
        "id": "heading"
      },
      {
        "label": "Description",
        "type": "text",
        "id": "description"
      }, {
        "label": "Button Text",
        "type": "text",
        "id": "banner_button_text"
      }, {
        "label": "Button Link",
        "type": "url",
        "id": "banner_button_link"
      }, {
        "type": "range",
        "id": "banner_text_width",
        "label": "Text Banner Width",
        "min": 0,
        "max": 600,
        "step": 6,
        "unit": "px",
        "default": 558
      }, {
        "type": "select",
        "id": "layout",
        "options": [
          {
            "value": "image_first",
            "label": "Image First"
          }, {
            "value": "text_first",
            "label": "Text First"
          }
        ],
        "default": "image_first",
        "label": "Layout",
        "info": "Choose the layout for the banner"
      }, {
        "type": "range",
        "id": "padding_top",
        "label": "Padding Top",
        "min": 0,
        "max": 150,
        "step": 5,
        "unit": "px",
        "default": 50
      }, {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding Bottom",
        "min": 0,
        "max": 150,
        "step": 5,
        "unit": "px",
        "default": 50
      }, {
        "type": "range",
        "id": "section_min_height",
        "label": "Section Minimum Height",
        "min": 100,
        "max": 600,
        "step": 25,
        "unit": "px",
        "default": 200
      }
    ],
    "presets": [
      {
        "name": "Custom Banner"
      }
    ]
  }
{% endschema %}