{{ 'custom.css' | asset_url | stylesheet_tag }}

{% if section.settings.my_custom_image != blank %}
  <div class="custom-banner" style="background-image: url({{ section.settings.my_custom_image | image_url: width: 1600 }}); padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    <div class="banner-text-container">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.description }}</p>
      <a href="{{ section.settings.banner_button_link }}" class="banner-button">
        {{ section.settings.banner_button_text }}
      </a>
    </div>
  </div>
{% endif %}

{% schema %}
  {
    "name": "Custom Image",
    "settings": [
      {
        "type": "image_picker",
        "id": "my_custom_image",
        "label": "Choose Image"
      },
      {
        "label": "Heading",
        "type": "text",
        "id": "heading"
      },
      {
        "label": "Description",
        "type": "text",
        "id": "description"
      },
      {
        "label": "Button Text",
        "type": "text",
        "id": "banner_button_text"
      }, {
        "label": "Button Link",
        "type": "url",
        "id": "banner_button_link"
      }, {
        "type": "range",
        "id": "padding_top",
        "label": "Padding Top",
        "min": 0,
        "max": 150,
        "step": 5,
        "unit": "px",
        "default": 50
      }, {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding Bottom",
        "min": 0,
        "max": 150,
        "step": 5,
        "unit": "px",
        "default": 50
      }
    ],
    "presets": [
      {
        "name": "Custom Banner"
      }
    ]
  }
{% endschema %}