{{ 'custom.css' | asset_url | stylesheet_tag }}

<section
  class="custom-feature-cards"
  style="
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="custom-feature-cards-wrapper text-banner-text-container">
    <div class="custom-feature-cards-grid">

      {% for block in section.blocks %}
        <div class="custom-feature-card" {{ block.shopify_attributes }}>

          {% if block.settings.icon != blank %}
            {{
              block.settings.icon
              | image_url: width: 120
              | image_tag
            }}
          {% endif %}

          <h3>{{ block.settings.title }}</h3>

          <p>{{ block.settings.description }}</p>

        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Feature Cards",
  "tag": "section",
  "class": "feature-cards-section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#D8B5B6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "CRUELTY FREE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Write your feature description here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Cards",
      "blocks": [
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        },
        {
          "type": "feature"
        }
      ]
    }
  ]
}
{% endschema %}